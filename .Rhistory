color = "Curve") +
#ylim(0,10) +
theme_classic() +
theme(
axis.title.x = element_text(size = 14),
axis.title.y = element_text(size = 14),
axis.text = element_text(size = 12),
legend.title = element_text(size = 14),
legend.text = element_text(size = 12),
legend.position = "right"
)
# 显示图形
print(p)
# ------------------------------
# 4. 绘制合并图
# ------------------------------
p <- ggplot() +
# GAM 拟合线（蓝色）及其置信区间（可选，如需去掉区间可注释掉 geom_ribbon）
geom_ribbon(data = new_data,
aes(x = Ne, ymin = variance - 1.96*se, ymax = variance + 1.96*se),
fill = "grey80", alpha = 0.4) +
geom_line(data = new_data,
aes(x = Ne, y = variance, color = "GAM fit"),
linewidth = 1) +
# 理论曲线（红色）
geom_line(data = theoretical,
aes(x = Ne, y = variance, color = "Theoretical"),
linewidth = 1, linetype = "solid") +
# 自定义颜色
scale_color_manual(values = c("GAM fit" = "blue", "Theoretical" = "red")) +
# 坐标轴标签（与原始图一致）
labs(x = expression(italic(N)[e]~"/"~10^4),
y = expression("Variance"~"/"~10^-6),
color = "Curve") +
ylim(0,20) +
theme_classic() +
theme(
axis.title.x = element_text(size = 14),
axis.title.y = element_text(size = 14),
axis.text = element_text(size = 12),
legend.title = element_text(size = 14),
legend.text = element_text(size = 12),
legend.position = "right"
)
# 显示图形
print(p)
