library(ggplot2)
library(mgcv)
library(readxl)
df <- read_excel("18.xlsx")
colnames(df) <- c("variance", "Ne", "Generation")
# 定义颜色渐变
blue_gradient <- c('#1c4f72', '#21618c', '#2874a6', '#2f86c1',
'#3398da', '#5cade2', '#85c1e9')
# 创建基础图形
p <- ggplot(df, aes(x = Ne, y = variance, color = Generation)) +
geom_point(size = 1, shape = 16, alpha = 0.7) +
scale_color_gradientn(
colours = blue_gradient,
limits = c(1, 100),
breaks = seq(0, 100, 25),
labels = seq(0, 100, 25)
) +
labs(
x = expression(italic(N)[e]~"/"~10^4),
y = expression("Variance"~"/"~10^-6),
color = expression("Generations"~"/"~10^4)
) +
theme_classic() +
theme(
axis.title.x = element_text(size = 14),
axis.title.y = element_text(size = 14),
axis.text = element_text(size = 12),
legend.title = element_text(size = 14),
legend.text = element_text(size = 12),
legend.position = "right"
)
mu <- 1.585e-8   # 中性突变率，可根据需要修改
theoretical <- data.frame(
Ne = new_data$Ne,
variance = 16 * mu^2 * (new_data$Ne * 1e4)^2 / 1e-4   # 直接换算，或直接用简化式
)
# 添加拟合线
p +
geom_line(data = theoretical,
aes(x = Ne, y = variance, color = "Theoretical"),
linewidth = 1, linetype = "solid")
# 添加拟合线
p +
geom_line(data = theoretical,
aes(x = Ne, y = variance),
linewidth = 1, linetype = "solid")
p
# 创建基础图形
p <- ggplot(df, aes(x = Ne, y = variance, color = '#2f86c1')) +
geom_point(size = 1, shape = 16, alpha = 0.7) +
) +
# 创建基础图形
p <- ggplot(df, aes(x = Ne, y = variance, color = '#2f86c1')) +
geom_point(size = 1, shape = 16, alpha = 0.7) +
labs(
x = expression(italic(N)[e]~"/"~10^4),
y = expression("Variance"~"/"~10^-6),
color = expression("Generations"~"/"~10^4)
) +
theme_classic() +
theme(
axis.title.x = element_text(size = 14),
axis.title.y = element_text(size = 14),
axis.text = element_text(size = 12),
legend.title = element_text(size = 14),
legend.text = element_text(size = 12),
legend.position = "right"
)
